generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Outlet / Shop ──────────────────────────────────────────────────────────────
model Shop {
  id         String   @id @default(cuid())
  tenantId   String   @unique  // matches id in tenants.json
  name       String
  city       String?
  address    String?
  branchCode String?
  createdAt  DateTime @default(now())

  // Extended location fields
  state      String?   // Province/State
  town       String?   // Town/Area within city
  phone      String?
  mobile     String?
  email      String?
  lat        Float?
  lng        Float?

  reviews Review[]
  users   User[]
}

// ── Application Users ─────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   // agent | manager | admin
  tenantId     String?
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  active       Boolean  @default(true)
  demoPassword String?  // plaintext — demo auto-fill only, never used for auth
  createdAt    DateTime @default(now())
}

// ── Review Session ─────────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])

  // Classification (from REVIEW hidden token)
  sentiment   String?  // positive | negative | complaint
  category    String?  // product | service | behavioral | facility | pricing | general
  subcategory String?  // e.g. "cold food", "rude cashier"
  rating      Int?     // 1–5
  items       String?  // JSON: string[]

  // Summary (from /api/summarize)
  summary   String?
  keyPoints String?  // JSON: string[]
  transcript String? // JSON: ChatHistory

  // Follow-up lifecycle
  status    String   @default("pending")  // pending | contacted | resolved
  ticketId       String?  @unique
  ticketType     String?  // complaint | negative | suggestion
  ticketPriority String?  // normal | high | urgent
  slaDueAt       DateTime?

  createdAt DateTime @default(now())

  lead Lead?
}

// ── Customer Contact (optional) ────────────────────────────────────────────────
model Lead {
  id       String  @id @default(cuid())
  reviewId String  @unique
  review   Review  @relation(fields: [reviewId], references: [id])

  name  String?
  email String?
  phone String?

  createdAt DateTime @default(now())
}
